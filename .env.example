# vBot — API keys
#
# Provider key format: <PROVIDER_UPPER>_API_KEY
# Service tokens keep their explicit names (for example TELEGRAM_BOT_TOKEN).

OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# web_search provider keys 
BRAVE_API_KEY=

# Ollama ignores bearer tokens; any non-empty value enables the built-in local provider.
OLLAMA_API_KEY=

# Telegram channel bot token.
TELEGRAM_BOT_TOKEN=

# Home Assistant
# HASS_TOKEN — Long-Lived Access Token from your HA profile page.
# Create one under: HA → your profile → Security → Long-Lived Access Tokens.
# Without a token the 4 HA tools (ha_list_entities, ha_get_state,
# ha_list_services, ha_call_service) will not be registered.
HASS_TOKEN=

# HASS_URL — optional, defaults to http://homeassistant.local:8123
# Set this if your HA instance is not reachable at the mDNS default.
HASS_URL=http://homeassistant.local:8123