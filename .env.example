# vBot — API keys

OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# web_search provider keys 
BRAVE_API_KEY=

# Ollama; any non-empty value enables the local provider.
OLLAMA_API_KEY=

# Telegram channel bot token.
TELEGRAM_BOT_TOKEN=

# Home Assistant
# HASS_TOKEN — Long-Lived Access Token from your HA profile page.
# Create one under: HA → your profile → Security → Long-Lived Access Tokens.
HASS_TOKEN=
# HASS_URL — optional, defaults to http://homeassistant.local:8123
HASS_URL=http://homeassistant.local:8123