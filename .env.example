# vControl — API keys
#
# Copy this file to the runtime .env and fill in your keys.
# Runtime .env path: OS user-data root (resolve_data_dir())/.env
# (Windows usually: %LOCALAPPDATA%/vControl/.env).
# The .env file is never committed to git.
#
# Provider key format: <PROVIDER_UPPER>_API_KEY
# Service tokens keep their explicit names (for example TELEGRAM_BOT_TOKEN).
#
# You can also set provider API keys in the app Settings panel.
# Telegram bot token is managed through the Telegram channel flow.

OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# web_search provider keys (Brave primary/default, Tavily fallback).
BRAVE_API_KEY=
TAVILY_API_KEY=

# Ollama ignores bearer tokens; any non-empty value enables the built-in local provider.
OLLAMA_API_KEY=local

# Telegram channel bot token.
TELEGRAM_BOT_TOKEN=
