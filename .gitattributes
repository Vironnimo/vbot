# Normalize line endings: all text files use LF in the repo, LF on checkout.
# This eliminates the "LF will be replaced by CRLF" warnings on Windows.
* text=auto eol=lf

# Binary files must never be touched.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.webp binary
*.webm binary
*.mp3 binary
*.mp4 binary
*.zip binary
*.gz binary
*.tar binary