{
  "id": "openrouter",
  "name": "OpenRouter",
  "adapter": "openai_compatible",
  "base_url": "https://openrouter.ai/api/v1",
  "connections": [
    {
      "id": "api-key",
      "type": "api_key",
      "label": "API Key",
      "auth": {
        "header": "Authorization",
        "prefix": "Bearer ",
        "credential_key": "OPENROUTER_API_KEY"
      }
    }
  ],
  "defaults": {
    "max_tokens": 4096,
    "temperature": 0.7
  },
  "extra_headers": {
    "HTTP-Referer": "https://vbot.app",
    "X-Title": "vBot"
  },
  "models_endpoint": "/models"
}
