{
  "id": "anthropic",
  "name": "Anthropic",
  "adapter": "anthropic",
  "base_url": "https://api.anthropic.com/v1",
  "models_endpoint": "/models",
  "connections": [
    {
      "id": "api-key",
      "type": "api_key",
      "label": "API Key",
      "auth": {
        "header": "x-api-key",
        "prefix": "",
        "credential_key": "ANTHROPIC_API_KEY"
      }
    }
  ],
  "defaults": {
    "max_tokens": 8192
  }
}
