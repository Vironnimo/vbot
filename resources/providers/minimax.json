{
  "id": "minimax",
  "name": "MiniMax",
  "adapter": "minimax",
  "base_url": "https://api.minimaxi.com/v1",
  "connections": [
    {
      "id": "api-key",
      "type": "api_key",
      "label": "API / Token Plan Key",
      "auth": {
        "header": "Authorization",
        "prefix": "Bearer ",
        "credential_key": "MINIMAX_API_KEY"
      }
    }
  ],
  "defaults": {
    "max_tokens": 8192,
    "temperature": 0.7
  },
  "models_endpoint": "/models"
}
